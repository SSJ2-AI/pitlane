{
  "name": "pitlane-voice",
  "version": "1.4.0",
  "description": "AI telephony microservice for PitLane — ElevenLabs + CDK/Fortellis integration",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "tsc --noEmit",
    "encrypt-secrets": "npm run build && node dist/scripts/encrypt-fortellis-secrets.js",
    "encrypt-secrets:selftest": "npm run build && node dist/scripts/encrypt-fortellis-secrets.js --selftest",
    "encrypt-secrets:dry-run": "npm run build && node dist/scripts/encrypt-fortellis-secrets.js --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^6.42.0",
    "twilio": "^6.0.2",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
